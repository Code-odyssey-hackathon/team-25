# ============================================================
# JanaVaani — Environment Variables
# Copy this file to .env and fill in your values.
# ============================================================

# Supabase Project (from supabase.com dashboard → Settings → API)
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_ID.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key_here

# OpenWeatherMap API (from openweathermap.org)
NEXT_PUBLIC_OPENWEATHER_KEY=your_openweather_key_here

# Hugging Face Inference API - AI-generated image detection
HUGGING_FACE_API_KEY=your_huggingface_api_key_here

# Hugging Face Inference API - CLIP embeddings for duplicate detection (same as above)
NEXT_PUBLIC_HUGGINGFACE_API_KEY=your_huggingface_api_key_here

# Google Gemini AI API for issue classification (from ai.google.dev)
GEMINI_API_KEY=your_gemini_api_key_here

# Groq API for reasoning fallback (optional, from groq.com)
GROQ_API_KEY=your_groq_api_key_here
